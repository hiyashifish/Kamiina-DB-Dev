---
const {id, title, caption, href} = Astro.props;
---
<a class="card" href={href ?? "#"} target="_blank">
    <h3>{title}</h3>
    <p>{caption}</p>
</div>

<style>
    .card {
        display: flex;
        flex-flow: column;
        border-bottom: 0.5px solid var(--color-primary);
        padding: 0px;
        padding-top: 1.5rem;
        padding-bottom: 1.5rem;
        color: var(--color-primary);
        text-decoration: none;
        background-color: rgba(0,0,0,0);
        height: 100px;
        justify-content: space-between;
    }

    .card:hover {
        background-color: var(--color-primary);
        color: var(--color-bg);
    }

    .card:hover p {
        color: var(--color-bg);
    }

    /* .card h3 :hover{
        color: var(--color-bg);
    } */
</style>